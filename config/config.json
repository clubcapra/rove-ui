{
  "header_settings": {
    "signals": [
      {"name": "VTX", "db": -65},
      {"name": "Microhard", "db": -72}
    ]
  },
  "udp_clients": [
    {
      "name": "telemetry_udp",
      "source": "udp://0.0.0.0:9999",
      "topic": "telemetry.raw",
      "parse_json": false,
      "buffer_size": 4096,
      "enabled": false
    }
  ],
  "console": true,
  "views": {
    "dashboard": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 2,
        "columns": 2,
        "spacing": 8
      },
      "content": [
        {
          "type": "webcamera",
          "name": "webcamera",
          "data": {
              "device_path": "/dev/video0",
              "responsive": {
                "min_width": 520,
                "freeze_below_min_width": true,
                "overflow_anchor": "center"
              }
          },
          "grid": {
            "row": 0,
            "column": 0,
            "row_span": 2,
            "column_span": 1
          }
        },
        {
          "type": "chart",
          "name": "Temperature",
          "data": {
              "chart_type": "band",
              "title": "Temperatures",
              "series_name": "Temperature",
              "label_key": "Parameter",
              "value_key": "Value",
              "data": [
                {"Parameter": "Odrive 1", "Value": 35, "unit": "°C"},
                {"Parameter": "Odrive 2", "Value": 45, "unit": "°C"},
                {"Parameter": "Odrive 3", "Value": 45, "unit": "°C"},
                {"Parameter": "Odrive 4", "Value": 45, "unit": "°C"}
              ]
          },
          "grid": {
            "row": 0,
            "column": 1,
            "row_span": 1,
            "column_span": 1
          }
        },
        {
          "type": "bitmap",
          "name": "Bitmap Preview",
          "data": {
              "source": "http://{{robot-ip}}/map_feed"
          },
          "grid": {
            "row": 1,
            "column": 1,
            "row_span": 1,
            "column_span": 1
          }
        }
      ]
    },
    "logs": {
      "type": "layout",
      "diaposition": "vertical",
      "content": [
        {
          "type": "console",
          "name": "event_log",
          "data": {
            "source": "wss://{{robot-ip}}/event_log_feed"
          }
        }
      ]
    }
  },
  "controls": {}
}