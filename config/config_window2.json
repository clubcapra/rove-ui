{
  "header_settings": {
    "signals": [
      {"name": "VTX", "db": -65},
      {"name": "Microhard", "db": -72}
    ],
    "E-Stop": {
      "active_color": "#ff0000",
      "inactive_color": "#00ff00",
      "topic": "estop_status"
    }
  },

  "console": true,
  "views": {
    "Cameras": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 1,
        "columns": 1,
        "spacing": 8
      },
      "content": [
          {
          "type": "camera",
          "name": "Camera",
            "data": {
            "mode": "webcamera",
            "rtsp": {
              "source": "rtsp://192.168.2.34:554/",
              "source_type": "rtsp"
            },
            "webcamera": {
              "device_path": "/dev/video0",
              "responsive": {
                "aspect_ratio": "4:3",
                "overflow_anchor": "center"
              }
            }
            },
            "grid": {
            "row": 0,
            "column": 0,
            "row_span": 1,
            "column_span": 1
            },
            "controls": {
      
            }
        }
      ]
    },
    "logs": {
      "type": "layout",
      "diaposition": "vertical",
      "content": [
        {
          "type": "console",
          "name": "event_log"
        }
      ]
    }
  },
  "controls": {}
}