{
  "header_settings": {
    "signals": [
      {"name": "MicroHard",  "host": "192.168.2.10"}
    ],
    "ping_interval_s": 2,
    "battery_topic": "battery.percentage",
    "E-Stop": {
      "active_color": "#ff0000",
      "inactive_color": "#00ff00",
      "topic": "estop_status"
    }
  },

  "udp_clients": [
    {
      "type": "udp_poll",
      "name": "vn300",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "vectornav_ttyUSB_VN300",
      "discovery_port_field": "data_port",
      "topic": "gnss",
      "topic_prefix": "gnss",
      "proto_type": "Vn300",
      "publish_field_topics": true,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    }
  ],
  "console": true,
  "views": {
    "Cameras": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 1,
        "columns": 1,
        "spacing": 8
      },
      "content": [
          {
          "type": "camera",
          "name": "Camera",
            "data": {
            "mode": "webcamera",
            "rtsp": {
              "source": "rtsp://192.168.2.34:554/",
              "source_type": "rtsp"
            },
            "webcamera": {
              "device_path": "/dev/video0",
              "responsive": {
                "aspect_ratio": "4:3",
                "overflow_anchor": "center"
              }
            }
            },
            "grid": {
            "row": 0,
            "column": 0,
            "row_span": 1,
            "column_span": 1
            },
            "controls": {

            }
        }
      ]
    },
    "Map": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 1,
        "columns": 1,
        "spacing": 8
      },
      "content": [
          {
            "type": "map",
            "name": "Carte",
            "data": {
              "initial_lat": 45.5017,
              "initial_lng": -73.5673,
              "initial_zoom": 17,
              "robot_position_lat_topic": "gnss.latitude",
              "robot_position_lng_topic": "gnss.longitude",
              "add_poi_at_topic": "costmap.poi"
            },
            "grid": {
              "row": 0,
              "column": 0,
              "row_span": 1,
              "column_span": 1
            }
          }
      ]
    },
    "logs": {
      "type": "layout",
      "diaposition": "vertical",
      "content": [
        {
          "type": "console",
          "name": "event_log"
        }
      ]
    }
  },
  "controls": {}
}
