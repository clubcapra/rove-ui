{
  "header_settings": {
    "signals": [
      {"name": "VTX",       "db": -65, "topic": "signals.VTX.db"},
      {"name": "Microhard", "db": -72, "topic": "signals.Microhard.db"}
    ],
    "battery_topic": "battery.percentage",
    "E-Stop": {
      "active_color": "#ff0000",
      "inactive_color": "#00ff00",
      "topic": "estop_status"
    }
  },

  "udp_clients": [
    {
      "type": "json_http_flat",
      "name": "mock_gnss",
      "source": "http://localhost:8080/gnss",
      "topic_prefix": "gnss",
      "poll_interval_ms": 500,
      "enabled": true
    },
    {
      "type": "json_http_flat",
      "name": "mock_battery",
      "source": "http://localhost:8080/battery",
      "topic_prefix": "battery",
      "poll_interval_ms": 2000,
      "enabled": true
    },
    {
      "type": "json_http_named_list",
      "name": "mock_signals",
      "source": "http://localhost:8080/signals",
      "topic_prefix": "signals",
      "list_key": "signals",
      "name_key": "name",
      "poll_interval_ms": 1000,
      "enabled": true
    }
  ],
  "console": true,
  "views": {
    "Cameras": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 1,
        "columns": 1,
        "spacing": 8
      },
      "content": [
          {
          "type": "camera",
          "name": "Camera",
            "data": {
            "mode": "webcamera",
            "rtsp": {
              "source": "rtsp://192.168.2.34:554/",
              "source_type": "rtsp"
            },
            "webcamera": {
              "device_path": "/dev/video0",
              "responsive": {
                "aspect_ratio": "4:3",
                "overflow_anchor": "center"
              }
            }
            },
            "grid": {
            "row": 0,
            "column": 0,
            "row_span": 1,
            "column_span": 1
            },
            "controls": {
      
            }
        }
      ]
    },
    "Map": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 1,
        "columns": 1,
        "spacing": 8
      },
      "content": [
          {
            "type": "map",
            "name": "Carte",
            "data": {
              "initial_lat": 45.5017,
              "initial_lng": -73.5673,
              "initial_zoom": 17,
              "robot_position_lat_topic": "gnss.latitude",
              "robot_position_lng_topic": "gnss.longitude"
            },
            "grid": {
              "row": 0,
              "column": 0,
              "row_span": 1,
              "column_span": 1
            }
          }
      ]
    },
    "logs": {
      "type": "layout",
      "diaposition": "vertical",
      "content": [
        {
          "type": "console",
          "name": "event_log"
        }
      ]
    }
  },
  "controls": {}
}