{
  "header_settings": {
    "signals": [
      {"name": "MicroHard",  "host": "192.168.2.10"}
    ],
    "ping_interval_s": 2,
    "battery_topic": "battery.percentage",
    "E-Stop": {
      "active_color": "#ff0000",
      "inactive_color": "#00ff00",
      "topic": "estop_status"
    }
  },
  "udp_clients": [
    {
      "type": "udp_poll",
      "name": "odrive_32",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "odrive_32",
      "discovery_port_field": "data_port",
      "topic": "odrive.32",
      "topic_prefix": "odrive.32",
      "proto_type": "DriveNodeState",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "odrive_33",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "odrive_33",
      "discovery_port_field": "data_port",
      "topic": "odrive.33",
      "topic_prefix": "odrive.33",
      "proto_type": "DriveNodeState",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "odrive_34",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "odrive_34",
      "discovery_port_field": "data_port",
      "topic": "odrive.34",
      "topic_prefix": "odrive.34",
      "proto_type": "DriveNodeState",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "odrive_31",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "odrive_31",
      "discovery_port_field": "data_port",
      "topic": "odrive.31",
      "topic_prefix": "odrive.31",
      "proto_type": "DriveNodeState",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "vn300",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "vectornav_ttyUSB_VN300",
      "discovery_port_field": "data_port",
      "topic": "gnss",
      "topic_prefix": "gnss",
      "proto_type": "Vn300",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "kinova_arm",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "kinova_arm",
      "discovery_port_field": "data_port",
      "topic": "kinova_arm",
      "topic_prefix": "kinova_arm",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    }

  ],
  "ros2_clients": [],
  "console": true,
  "views": {
    "dashboard": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 3,
        "columns": 2,
        "spacing": 8
      },
      "content": [
        {
          "type": "chart",
          "name": "Position Moteurs",
          "data": {
              "chart_type": "lines",
              "title": "Position Moteurs",
              "series_name": "Position",
              "label_key": "Parameter",
              "value_key": "Value",
              "data": [
                {"Parameter": "FL", "Value": 0, "unit": "turns", "topic": "odrive.32.pos_estimate"},
                {"Parameter": "RL", "Value": 0, "unit": "turns", "topic": "odrive.33.pos_estimate"},
                {"Parameter": "FR", "Value": 0, "unit": "turns", "topic": "odrive.34.pos_estimate"},
                {"Parameter": "RR", "Value": 0, "unit": "turns", "topic": "odrive.31.pos_estimate"}
              ]
          },
          "grid": {
            "row": 0,
            "column": 0,
            "row_span": 1,
            "column_span": 1
          }
        },
        {
          "type": "chart",
          "name": "Temp. Moteurs",
          "data": {
              "chart_type": "band",
              "title": "Températures Moteurs",
              "series_name": "Temperature",
              "label_key": "Parameter",
              "value_key": "Value",
              "data": [
                {"Parameter": "FL", "Value": 0, "unit": "°C", "topic": "odrive.32.motor_temp"},
                {"Parameter": "RL", "Value": 0, "unit": "°C", "topic": "odrive.33.motor_temp"},
                {"Parameter": "FR", "Value": 0, "unit": "°C", "topic": "odrive.34.motor_temp"},
                {"Parameter": "RR", "Value": 0, "unit": "°C", "topic": "odrive.31.motor_temp"}
              ]
          },
          "grid": {
            "row": 0,
            "column": 1,
            "row_span": 1,
            "column_span": 1
          }
        },
        {
          "type": "chart",
          "name": "Temp. Drivers",
          "data": {
              "chart_type": "band",
              "title": "Températures Drivers",
              "series_name": "Temperature",
              "label_key": "Parameter",
              "value_key": "Value",
              "data": [
                {"Parameter": "FL", "Value": 0, "unit": "°C", "topic": "odrive.32.fet_temp"},
                {"Parameter": "RL", "Value": 0, "unit": "°C", "topic": "odrive.33.fet_temp"},
                {"Parameter": "FR", "Value": 0, "unit": "°C", "topic": "odrive.34.fet_temp"},
                {"Parameter": "RR", "Value": 0, "unit": "°C", "topic": "odrive.31.fet_temp"}
              ]
          },
          "grid": {
            "row": 1,
            "column": 0,
            "row_span": 1,
            "column_span": 1
          }
        },
        {
          "type": "robot",
          "name": "Rove3D",
          "data": {
            "urdf": "src/media/rove_urdf/rove.urdf",
            "link_colors": {
              "Core":              "#c8c8d0",
              "FlipperFL":         "#72c572",
              "FlipperBL":         "#6b6bc4",
              "FlipperFR":         "#d56868",
              "FlipperBR":         "#e1e17c",
              "DrumFL":            "#5aab5a",
              "DrumBL":            "#5a5aaa",
              "DrumFR":            "#bb5555",
              "DrumBR":            "#c4c45a",
              "Base":              "#b0b8c8",
              "ASection":          "#8fa0b8",
              "BSection":          "#7890a8",
              "JointA":            "#a0b0c0",
              "JointB":            "#a0b0c0",
              "JointGripper":      "#c8a070",
              "dji_mid360":        "#303040",
              "vn300_vectornav":   "#404050",
              "chinese_camera":    "#202028",
              "chinese_camera_2":  "#202028",
              "chinese_camera_3":  "#202028"
            },
            "controls": {
              "joint_angles": [
               
                {"joint": "joint_revolute_9",  "topic": "kinova_arm.joint_1_pos", "scale": 0.01745, "offset": 1.5708},
                {"joint": "joint_revolute_10", "topic": "kinova_arm.joint_2_pos", "scale": -0.01745, "offset": 0},
                {"joint": "joint_revolute_11", "topic": "kinova_arm.joint_3_pos", "scale": 0.01745, "offset": 1.5708},
                {"joint": "joint_revolute_12", "topic": "kinova_arm.joint_4_pos", "scale": 0.01745, "offset": 0},
                {"joint": "joint_revolute_13", "topic": "kinova_arm.joint_5_pos", "scale": 0.01745, "offset": 1.5708},
                {"joint": "joint_revolute_14", "topic": "kinova_arm.joint_6_pos", "scale": 0.01745, "offset": 1.5708}

              ],
              "robot_pose": {
                "roll_topic":  "gnss.roll",
                "pitch_topic": "gnss.pitch",
                "yaw_topic":   "gnss.yaw"
              }
            }
          },
          "grid": {
            "row": 2,
            "column": 0,
            "row_span": 1,
            "column_span": 1
          }
        },
        {
          "type": "bitmap",
          "name": "Costmap",
          "data": {
            "source": "http://localhost:8080/map_feed",
            "cornerPositionWidth": 8,
            "cornerPositionHeight": 8,
            "click_topic": "costmap.click",
            "poi_topic": "costmap.poi",
            "gps_lat_topic": "gnss.latitude",
            "gps_lng_topic": "gnss.longitude",
            "gps_yaw_topic": "gnss.yaw",

            "robot_cursor_image": "src/media/icons/robot_icons.png",
            "robot_cursor_size": [40, 40],
            "poi_image": "src/media/icons/poi_icons.png",
            "poi_size": [24, 32]
          },
          "grid": {
            "row": 1,
            "column": 1,
            "row_span": 2,
            "column_span": 1
          }
        }
      ]
    },
    "Map": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 1,
        "columns": 1,
        "spacing": 8
      },
      "content": [
        {
          "type": "map",
          "name": "Carte",
          "data": {
            "initial_lat": 0,
            "initial_lng": 0,
            "initial_zoom": 17,
            "robot_position_lat_topic": "gnss.latitude",
            "robot_position_lng_topic": "gnss.longitude",
            "robot_position_yaw_topic": "gnss.yaw",
            "add_poi_at_topic": "costmap.poi",
            "ocr_url": "http://localhost:8080/camera/ocr",
            "robot_cursor_image": "src/media/icons/robot_icons.png",
            "robot_cursor_size": [40, 40],
            "poi_image": "src/media/icons/poi_icons.png",
            "poi_size": [24, 32]
          },
          "grid": {
            "row": 0,
            "column": 0,
            "row_span": 1,
            "column_span": 1
          }
        }
      ]
    },
    "logs": {
      "type": "layout",
      "diaposition": "vertical",
      "content": [
        {
          "type": "console",
          "name": "event_log"
        }
      ]
    }
  }

}
