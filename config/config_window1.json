{
  "header_settings": {
    "signals": [
      {"name": "MicroHard",  "host": "192.168.2.2"}
    ],
    "ping_interval_s": 2,
    "battery_topic": "battery.percentage",
    "E-Stop": {
      "active_color": "#ff0000",
      "inactive_color": "#00ff00",
      "topic": "estop_status"
    }
  },
  "udp_clients": [
    {
      "type": "udp_poll",
      "name": "odrive_32",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "odrive_32",
      "discovery_port_field": "data_port",
      "topic": "odrive.32",
      "topic_prefix": "odrive.32",
      "proto_type": "DriveNodeState",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "odrive_33",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "odrive_33",
      "discovery_port_field": "data_port",
      "topic": "odrive.33",
      "topic_prefix": "odrive.33",
      "proto_type": "DriveNodeState",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "odrive_34",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "odrive_34",
      "discovery_port_field": "data_port",
      "topic": "odrive.34",
      "topic_prefix": "odrive.34",
      "proto_type": "DriveNodeState",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "odrive_31",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "odrive_31",
      "discovery_port_field": "data_port",
      "topic": "odrive.31",
      "topic_prefix": "odrive.31",
      "proto_type": "DriveNodeState",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    },
    {
      "type": "udp_poll",
      "name": "vn300",
      "base_url": "http://192.168.2.2:8080",
      "discovery_endpoint": "/discover",
      "discovery_sensor_id": "vectornav_ttyUSB_VN300",
      "discovery_port_field": "data_port",
      "topic": "gnss",
      "topic_prefix": "gnss",
      "proto_type": "Vn300",
      "publish_field_topics": true,
      "poll_interval_ms": 100,
      "recv_timeout_s": 2.0,
      "rediscovery_interval_s": 30,
      "enabled": true
    }

  ],
  "ros2_clients": [],
  "console": true,
  "views": {
    "dashboard": {
      "type": "layout",
      "diaposition": "grid",
      "grid": {
        "rows": 3,
        "columns": 2,
        "spacing": 8
      },
      "content": [
        {
          "type": "chart",
          "name": "Position Moteurs",
          "data": {
              "chart_type": "lines",
              "title": "Position Moteurs",
              "series_name": "Position",
              "label_key": "Parameter",
              "value_key": "Value",
              "data": [
                {"Parameter": "FL", "Value": 0, "unit": "turns", "topic": "odrive.32.pos_estimate"},
                {"Parameter": "RL", "Value": 0, "unit": "turns", "topic": "odrive.33.pos_estimate"},
                {"Parameter": "FR", "Value": 0, "unit": "turns", "topic": "odrive.34.pos_estimate"},
                {"Parameter": "RR", "Value": 0, "unit": "turns", "topic": "odrive.31.pos_estimate"}
              ]
          },
          "grid": {
            "row": 0,
            "column": 0,
            "row_span": 1,
            "column_span": 1
          }
        },
        {
          "type": "chart",
          "name": "Temp. Moteurs",
          "data": {
              "chart_type": "band",
              "title": "Températures Moteurs",
              "series_name": "Temperature",
              "label_key": "Parameter",
              "value_key": "Value",
              "data": [
                {"Parameter": "FL", "Value": 0, "unit": "°C", "topic": "odrive.32.motor_temp"},
                {"Parameter": "RL", "Value": 0, "unit": "°C", "topic": "odrive.33.motor_temp"},
                {"Parameter": "FR", "Value": 0, "unit": "°C", "topic": "odrive.34.motor_temp"},
                {"Parameter": "RR", "Value": 0, "unit": "°C", "topic": "odrive.31.motor_temp"}
              ]
          },
          "grid": {
            "row": 0,
            "column": 1,
            "row_span": 1,
            "column_span": 1
          }
        },
        {
          "type": "chart",
          "name": "Temp. Drivers",
          "data": {
              "chart_type": "band",
              "title": "Températures Drivers",
              "series_name": "Temperature",
              "label_key": "Parameter",
              "value_key": "Value",
              "data": [
                {"Parameter": "FL", "Value": 0, "unit": "°C", "topic": "odrive.32.fet_temp"},
                {"Parameter": "RL", "Value": 0, "unit": "°C", "topic": "odrive.33.fet_temp"},
                {"Parameter": "FR", "Value": 0, "unit": "°C", "topic": "odrive.34.fet_temp"},
                {"Parameter": "RR", "Value": 0, "unit": "°C", "topic": "odrive.31.fet_temp"}
              ]
          },
          "grid": {
            "row": 1,
            "column": 0,
            "row_span": 1,
            "column_span": 1
          }
        },
        {
          "type": "threejsViewer",
          "name": "URDF Preview",
          "data": {
            "object_sources": [
                {
                    "name": "RoveCore",
                    "source": "media/rove_base.obj",
                    "position": [0, 0, 0],
                    "rotation": [0, 0, 0],
                    "rotation_unit": "degrees",
                    "scale": [3, 3, 3],
                    "center": true,
                    "base_on_ground": true,
                    "color": "#e2d4d4"
                },
                {
                    "name": "Flipper FL",
                    "source": "media/rove_flipper.obj",
                  "position": [-0.52, 0.3, 0.6],
                  "pivot_offset": [0.16, 0.1, 0.0],
                    "rotation": [0, 0, 0],
                    "scale": [3, 3, 3],
                    "rotation_unit": "degrees",
                    "center": true,
                    "base_on_ground": true,
                    "color": "#72c572"
                },
                {
                    "name": "Flipper RL",
                    "source": "media/rove_flipper.obj",
                  "position": [0.52, 0.2, 0.66],
                  "pivot_offset": [0.16, 0.1, 0.02],
                    "rotation": [0, 0, 180],
                    "rotation_unit": "degrees",
                    "scale": [3, 3, 3],
                    "center": true,
                    "base_on_ground": true,
                    "color": "#6b6bc4"
                },
                {
                    "name": "Flipper FR",
                    "source": "media/rove_flipper.obj",
                  "position": [-0.58, 0.24, -0.66],
                  "pivot_offset": [0.14, 0.08, -0.02],
                    "rotation": [0, 0, 0],
                    "rotation_unit": "degrees",
                    "scale": [3, 3, 3],
                    "center": true,
                    "base_on_ground": true,
                    "color": "#d56868"
                },
                {
                    "name": "Flipper RR",
                    "source": "media/rove_flipper.obj",
                  "position": [0.52, 0.26, -0.72],
                  "pivot_offset": [0.16, 0.08, -0.04],
                    "rotation": [0, 0, 180],
                    "rotation_unit": "degrees",
                    "scale": [3, 3, 3],
                    "center": true,
                    "base_on_ground": true,
                    "color": "#e1e17c"
                }
            ]
          },
          "grid": {
            "row": 2,
            "column": 0,
            "row_span": 1,
            "column_span": 1
          },
          "controls": {
            "input": {
              "enabled": true,
              "yaw_topic": "input.axis.10",
              "pitch_topic": "input.axis.11",
              "sensitivity": 0.04,
              "deadzone": 0.08,
              "invert_x": false,
              "invert_y": true
            },
            "object_rotations": [
              {"object": "Flipper FL", "axis": "z", "topic": "odrive.32.pos_estimate", "scale":  0.01745, "offset": 0},
              {"object": "Flipper RL", "axis": "z", "topic": "odrive.33.pos_estimate", "scale": -0.01745, "offset": 3.14159},
              {"object": "Flipper FR", "axis": "z", "topic": "odrive.34.pos_estimate", "scale":  0.01745, "offset": 0},
              {"object": "Flipper RR", "axis": "z", "topic": "odrive.31.pos_estimate", "scale": -0.01745, "offset": 3.14159}
            ]
          }
        },
        {
          "type": "bitmap",
          "name": "Costmap",
          "data": {
            "source": "http://localhost:8080/map_feed",
            "cornerPositionWidth": 8,
            "cornerPositionHeight": 8,
            "click_topic": "costmap.click",
            "poi_topic": "costmap.poi",
            "gps_lat_topic": "gnss.latitude",
            "gps_lng_topic": "gnss.longitude",
            "gps_yaw_topic": "gnss.yaw"
          },
          "grid": {
            "row": 1,
            "column": 1,
            "row_span": 2,
            "column_span": 1
          }
        }
      ]
    },
    "logs": {
      "type": "layout",
      "diaposition": "vertical",
      "content": [
        {
          "type": "console",
          "name": "event_log"
        }
      ]
    }
  }

}
